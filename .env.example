POSTGRES_DB=ari
POSTGRES_USER=ari
POSTGRES_PASSWORD=ari
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ari:ari@localhost:5432/ari
ARI_ENV=local
ARI_TIMEZONE=America/Los_Angeles

# ARI's brain (ari_core/brain.py) and iMessage scripts
ANTHROPIC_API_KEY=
ARI_IMESSAGE_TO=
# Every identifier your self-thread might appear under (phone + Apple ID email) — Messages
# can fork the same conversation across identities. Falls back to ARI_IMESSAGE_TO if unset.
ARI_IMESSAGE_SELF_IDENTIFIERS=
ARI_BRAIN_MODEL=claude-sonnet-4-6
# Encrypts/decrypts OAuth tokens for registered MCP skills (ari_core/skills.py)
# before they're stored in skill_registrations.encrypted_token. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key makes every stored skill token unrecoverable — back it up
# outside the repo, never commit it.
ARI_SKILL_TOKEN_KEY=
